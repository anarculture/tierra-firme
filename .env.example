# Tierra Firme — env vars de producción.
# Copia a .env y llena. Formato compatible con systemd EnvironmentFile:
# comentarios SOLO en línea propia (un # tras el valor se vuelve parte del valor).

# --- Intake WhatsApp (Zavu) ---
# Secret del webhook del sender "Tierra Firme" (whsec_...). OBLIGATORIO salvo --dev.
ZAVU_WEBHOOK_SECRET=
# API key (zv_...) para bajar media y enviar respuestas.
ZAVU_API_KEY=
# Override del host de la API (default https://api.zavu.dev).
#ZAVU_API=

# --- LLM (Gemini, key única funded) ---
# Transcripción, visión, destila/analiza. Fallback: ANALIZA_API_KEY (key humanitas).
VLM_API_KEY=
#ANALIZA_API_KEY=
# Overrides opcionales de modelo/endpoint (defaults en código):
#ANALIZA_MODEL= ANALIZA_BASE_URL= DESTILA_MODEL= DESTILA_BASE_URL= TRANSCRIBE_MODEL=

# --- Panel operador (npm run revisar) ---
# HTTP Basic. Setear ANTES de tunelizar el panel.
REVISAR_TOKEN=

# --- Saliente (reply.py) ---
# Acuse de recibo WhatsApp. OFF por default; ojo ventana 24h de Meta.
REPLY_ENABLED=0
